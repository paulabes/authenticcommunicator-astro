---
import { reviews } from '../data/reviews';
const { text, author, date } = Astro.props;
const fixed = !!text;
const reviewCount = reviews.length;
---

<section class="py-24 bg-[#F8F3EA] text-[#050615]" data-review-section={fixed ? undefined : ''}>
    <div class="max-w-[900px] mx-auto px-6 text-center">
        <div class="flex items-center justify-center gap-2 mb-4">
            <iconify-icon icon="mdi:google" width="20" class="text-[#050615]"></iconify-icon>
            <span class="text-[10px] uppercase tracking-widest text-gray-600 font-medium">Google Review - 5.0 / {reviewCount} Reviews</span>
        </div>
        <div class="flex justify-center gap-1 mb-8">
            {Array(5).fill(0).map(() => <iconify-icon icon="solar:star-bold" width="24" class="text-[#C4A470]"></iconify-icon>)}
        </div>
        <blockquote class="text-lg md:text-xl mb-8 text-[#050615] leading-relaxed font-light italic" data-review-text>{fixed ? `“${text}”` : ''}</blockquote>
        <p class="font-medium text-[#050615]" data-review-name>{fixed ? author : ''}</p>
        <p class="text-sm text-gray-500" data-review-date>{fixed ? date : ''}</p>
    </div>
</section>

<script is:inline define:vars={{ reviews }}>
(function() {
    const sections = document.querySelectorAll('[data-review-section]');
    const used = new Set();
    sections.forEach(section => {
        let idx;
        do { idx = Math.floor(Math.random() * reviews.length); } while (used.has(idx) && used.size < reviews.length);
        used.add(idx);
        const r = reviews[idx];
        section.querySelector('[data-review-text]').textContent = '“' + r.text + '”';
        section.querySelector('[data-review-name]').textContent = r.name;
        section.querySelector('[data-review-date]').textContent = r.date;
    });
})();
</script>
