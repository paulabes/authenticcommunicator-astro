---
import { reviews } from '../data/reviews';
const size = Astro.props.size ?? 'large';
---

<section class="py-24 bg-[#0c1a3a]" data-review-section>
    <div class={`${size === 'large' ? 'max-w-[900px]' : 'max-w-[800px]'} mx-auto px-6 text-center`}>
        <div class="flex items-center justify-center gap-2 mb-4">
            <iconify-icon icon="mdi:google" width={size === 'large' ? '20' : '18'} class="text-white"></iconify-icon>
            <span class="text-[10px] uppercase tracking-widest text-gray-400 font-medium">Google Review - 5.0 / 14 Reviews</span>
        </div>
        <div class="flex justify-center gap-1 mb-8">
            {Array(5).fill(0).map(() => <iconify-icon icon="solar:star-bold" width={size === 'large' ? '24' : '20'} class="text-[#C4A470]"></iconify-icon>)}
        </div>
        <blockquote class={`${size === 'large' ? 'text-lg md:text-xl mb-8' : 'text-base md:text-lg mb-6'} text-gray-300 leading-relaxed font-light italic`} data-review-text></blockquote>
        <p class={`font-medium text-white ${size === 'large' ? '' : 'text-sm'}`} data-review-name></p>
        <p class={`${size === 'large' ? 'text-sm' : 'text-xs'} text-gray-500`} data-review-date></p>
    </div>
</section>

<script is:inline define:vars={{ reviews }}>
(function() {
    const sections = document.querySelectorAll('[data-review-section]');
    const used = new Set();
    sections.forEach(section => {
        let idx;
        do { idx = Math.floor(Math.random() * reviews.length); } while (used.has(idx) && used.size < reviews.length);
        used.add(idx);
        const r = reviews[idx];
        section.querySelector('[data-review-text]').textContent = '\u201C' + r.text + '\u201D';
        section.querySelector('[data-review-name]').textContent = r.name;
        section.querySelector('[data-review-date]').textContent = r.date;
    });
})();
</script>
