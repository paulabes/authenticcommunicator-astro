---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbSchema } from '../../data/site';
import fs from 'node:fs';
import path from 'node:path';
import { holdingPosts } from '../../data/holdingPosts';

interface PostMeta {
  slug: string;
  title: string;
  date: string;
  dateFormatted: string;
  category: string;
  excerpt: string;
  image?: string;
}

function parseFrontmatter(src: string): { meta: Record<string, string>; body: string } {
  const match = src.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
  if (!match) return { meta: {}, body: src };
  const meta: Record<string, string> = {};
  for (const line of match[1].split('\n')) {
    const m = line.match(/^([A-Za-z0-9_]+):\s*(.*)$/);
    if (!m) continue;
    meta[m[1]] = m[2].trim().replace(/^["']|["']$/g, '');
  }
  return { meta, body: match[2] };
}

function detectCategory(title: string): string {
  const t = title.toLowerCase();
  const rules: [string, string[]][] = [
    ['Public Speaking', ['public speaking', 'keynote', 'presentation', 'ted talk', 'storytelling', 'pitch']],
    ['Voice Technique', ['vocal', 'voice technique', 'projection', 'resonance', 'breathing']],
    ['Pronunciation', ['pronunciation', 'accent', 'articulation', 'intonation']],
    ['Performance Anxiety', ['stage fright', 'nerves', 'anxiety', 'fear of speaking']],
    ['Communication', ['communication', 'body language', 'non-verbal', 'listening']],
    ['Media Training', ['media training', 'interview', 'podcast']],
  ];
  for (const [cat, keywords] of rules) {
    if (keywords.some(kw => t.includes(kw))) return cat;
  }
  return 'Communication';
}

const blogDir = path.resolve('./src/content/blog');
const posts: PostMeta[] = [];

if (fs.existsSync(blogDir)) {
  const files = fs.readdirSync(blogDir).filter(f => f.endsWith('.md') && !f.endsWith('.editor.md'));

  for (const file of files) {
    const raw = fs.readFileSync(path.join(blogDir, file), 'utf-8');
    const { meta, body } = parseFrontmatter(raw);

    const titleMatch = body.match(/^#\s+(.+)$/m);
    const title = meta.title || (titleMatch ? titleMatch[1] : file.replace('.md', '').replace(/-/g, ' '));

    const dateMatch = file.match(/^(\d{4}-\d{2}-\d{2})/);
    const dateStr = meta.date || (dateMatch ? dateMatch[1] : '');
    const date = dateStr ? new Date(dateStr) : new Date();
    const dateFormatted = dateStr
      ? date.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })
      : '';

    const slug = file.replace(/^\d{4}-\d{2}-\d{2}-?/, '').replace('.md', '');

    let excerpt = meta.excerpt || '';
    if (!excerpt) {
      const bodyText = body.replace(/^#\s+.+\n*/m, '').replace(/[#*_\[\]()>`]/g, '').trim();
      excerpt = bodyText.length > 160 ? bodyText.slice(0, 160).replace(/\s+\S*$/, '') + '...' : bodyText;
    }

    const category = meta.category || detectCategory(title);
    const image = meta.image || undefined;

    posts.push({ slug, title, date: dateStr, dateFormatted, category, excerpt, image });
  }

  posts.sort((a, b) => (b.date || '').localeCompare(a.date || ''));
}

const displayPosts: PostMeta[] = posts.length > 0
  ? posts
  : holdingPosts.map(p => ({ ...p, date: '' }));
---

<Base
    title="Inspiration"
    description="Practical articles on public speaking, voice technique, performance anxiety, and authentic communication by London-based coach Alice Deville."
    jsonLd={[breadcrumbSchema([
      { name: 'Home', url: '/' },
      { name: 'Inspiration', url: '/inspiration' },
    ])]}
>

<!-- Hero Background -->
<div class="fixed top-0 w-full h-screen -z-10">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/authentic-communicator-global-alice.jpg'); opacity: 0.8;"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#050615] via-[#050615]/90 to-[#050615]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050615]/50 to-[#050615]"></div>
</div>

<!-- Hero -->
<section class="pt-36 pb-16 lg:px-12 px-6">
    <div class="max-w-[1200px] mx-auto text-center">
        <div class="flex justify-center mb-5">
            <Breadcrumbs items={[
                { name: 'Home', url: '/' },
                { name: 'Inspiration' },
            ]} />
        </div>
        <span class="text-[11px] tracking-[0.25em] text-[#C4A470] uppercase font-medium block mb-4">Insights & Tips</span>
        <h1 class="text-5xl md:text-6xl font-serif text-white mb-6">Inspiration</h1>
        <p class="text-gray-400 font-light max-w-xl text-lg leading-relaxed mx-auto">Practical articles on public speaking, voice technique, performance anxiety, and authentic communication - written by Alice Deville.</p>
    </div>
</section>

<!-- Blog Grid -->
<section class="py-16 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {displayPosts.map(post => (
                <a href={`/inspiration/${post.slug}`} class="group block bg-white border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col">
                    {post.image && (
                        <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
                            <img src={post.image} alt={post.title} width="800" height="600" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                            <span class="absolute top-4 left-4 bg-[#050615] text-[#C4A470] text-[9px] uppercase tracking-widest font-medium px-3 py-1.5">{post.category}</span>
                        </div>
                    )}
                    {!post.image && (
                        <div class="bg-[#050615] px-6 py-3 flex items-center justify-between">
                            <span class="text-[10px] uppercase tracking-widest text-[#C4A470] font-medium">{post.category}</span>
                            <span class="text-[10px] uppercase tracking-widest text-gray-500">{post.dateFormatted}</span>
                        </div>
                    )}
                    <div class="p-8 flex flex-col flex-1">
                        {post.image && <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-3">{post.dateFormatted}</p>}
                        <h2 class="text-xl font-serif text-[#050615] mb-4 group-hover:text-[#C4A470] transition-colors leading-tight">{post.title}</h2>
                        <p class="text-sm text-gray-500 font-light leading-relaxed mb-6 flex-1">{post.excerpt}</p>
                        <span class="text-[10px] uppercase tracking-[0.2em] font-medium text-[#C4A470] group-hover:text-[#050615] transition-colors">Read more &rarr;</span>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-16 bg-[#0c1a3a]">
    <div class="max-w-[800px] mx-auto px-6 text-center">
        <h2 class="text-3xl font-serif text-white mb-4">Ready to transform your communication?</h2>
        <p class="text-gray-400 font-light mb-8">Don't just read about it. Book a session with Alice and experience the difference.</p>
        <a href="/free-consultation" class="btn-primary">Book a Free Discovery Call</a>
    </div>
</section>

</Base>
