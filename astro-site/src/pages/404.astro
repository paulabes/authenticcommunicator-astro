---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found">

<section class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center">
        <p class="text-[#C4A470] font-serif text-8xl mb-4">404</p>
        <h1 class="text-3xl font-serif text-white mb-4">Page Not Found</h1>
        <p class="text-gray-400 font-light mb-8 max-w-md mx-auto">The page you're looking for doesn't exist or has been moved.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/" class="btn-primary">Back to Home</a>
            <a href="/contact" class="btn-secondary btn-secondary-light">Contact Alice</a>
        </div>
    </div>
</section>

</Base>
