---
import Base from '../../layouts/Base.astro';
import GoogleReview from '../../components/GoogleReview.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { serviceSchema, breadcrumbSchema, faqPageSchema, siteOrigin } from '../../data/site';

const description = 'The Confident Pronunciation Package is a targeted 1:1 UK English pronunciation and accent clarity programme with Alice Deville. Build clarity, rhythm, and ease in professional English without losing your identity.';

const faqs = [
  {
    q: 'Is this only for non-native English speakers?',
    a: "No. The Confident Pronunciation Package works for both native and non-native English speakers who want to be understood clearly and sound more assured. Non-native speakers usually want to smooth intonation, tighten specific sounds that mark them as foreign in a UK English setting, and gain confidence on video calls and presentations. Native speakers often arrive wanting to soften a regional accent for international business, sharpen articulation after years of mumbling in meetings, or develop a more grounded vocal quality for leadership. The core work - mouth position, rhythm, stress patterns, breath support - applies to both, tailored to your current voice and the professional settings you work in.",
  },
  {
    q: 'Will I lose my accent completely?',
    a: "No, and that is not the aim. Your accent is part of your identity, and erasing it would make you sound less like yourself, not more credible. The goal of the Confident Pronunciation Package is clarity and ease: you are understood the first time, without having to repeat yourself on calls, and you sound at home in professional UK English settings without losing who you are. In practice that means adjusting the sounds and rhythms that slow listeners down, while keeping the melodic colour, warmth, and regional character of your voice. Many clients tell me that after working together they feel more, not less, like themselves when they speak.",
    link: '/free-consultation',
    cta: 'Book a Free Consultation',
  },
  {
    q: 'How quickly will I see results?',
    a: "Most clients notice a measurable change within the first 3 to 4 sessions, and colleagues often start remarking on it around the same time. Pronunciation is a motor skill, so progress is proportional to practice between sessions - typically 10 to 15 minutes a day on the exercises I set. Early wins come from fixing one or two high-frequency sounds that create the biggest listener friction; that alone can transform how you sound on calls within a few weeks. Deeper, permanent change in rhythm and intonation usually takes 3 to 6 months of consistent work. I build a realistic timeline into your first session so expectations match the effort you can sustain.",
  },
  {
    q: "What's different about your approach?",
    a: "As a Guildhall-trained opera singer with a decade of performing experience, I have a finely tuned ear for voice, articulation, and intonation that goes well beyond typical pronunciation coaching. Opera training makes you hyper-aware of vowel shape, resonance, and how breath moves through the body, and those are exactly the levers that move pronunciation in adults. I combine that technical ear with more than 10 years of coaching professionals from BlackRock, Deloitte, JP Morgan and Google, so the work always stays grounded in how you actually need to sound - in board meetings, client calls, and presentations. I hear patterns most coaches miss and give you the exercises to change them.",
    link: '/contact',
    cta: 'Get in Touch',
  },
];
---

<Base
    title="Confident Pronunciation Package"
    description={description}
    image="/images/confident-pronunciation-package.jpg"
    jsonLd={[
      serviceSchema({
        name: 'Confident Pronunciation Package',
        slug: 'confident-pronunciation',
        serviceType: 'UK English pronunciation and accent clarity coaching',
        description,
        image: '/images/confident-pronunciation-package.jpg',
      }),
      breadcrumbSchema([
        { name: 'Home', url: '/' },
        { name: 'Packages', url: '/packages' },
        { name: 'Confident Pronunciation', url: '/packages/confident-pronunciation' },
      ]),
      faqPageSchema(faqs, `${siteOrigin}/packages/confident-pronunciation`),
    ]}
>

<style>
  .pkg { --pkg-accent: #6B8E85; }
</style>

<div class="pkg">

<!-- Hero Background -->
<div class="fixed top-0 w-full h-screen -z-10">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/authentic-communicator-global-alice.jpg'); opacity: 0.8;"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#050615] via-[#050615]/90 to-[#050615]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050615]/50 to-[#050615]"></div>
</div>

<!-- Hero -->
<section class="pt-36 pb-16 lg:px-12 px-6">
    <div class="max-w-[1200px] mx-auto text-center">
        <div class="flex justify-center mb-5">
            <Breadcrumbs items={[
                { name: 'Home', url: '/' },
                { name: 'Packages', url: '/packages' },
                { name: 'Confident Pronunciation' },
            ]} />
        </div>
        <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">Coaching Package</span>
        <h1 class="text-5xl md:text-6xl font-serif text-white mb-6">Confident Pronunciation Package</h1>
        <p class="text-gray-400 font-light max-w-xl text-lg leading-relaxed mx-auto">Confident UK English pronunciation. Speak clearly and be understood with ease - whether English is your first language or an additional one.</p>
    </div>
</section>

<!-- Intro: image + paragraph, airy -->
<section class="py-28 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <img src="/images/confident-pronunciation-package.jpg" alt="Pronunciation Coaching Session" class="w-full rounded-sm">
            <div class="lg:pr-6">
                <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-5">Who Is This For</span>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8 leading-tight">Clarity, not conformity.</h2>
                <p class="text-gray-600 font-light leading-relaxed text-lg">This package is for professionals who want to speak English with greater clarity and confidence. Whether you're a non-native speaker looking to refine your accent for professional settings, or a native speaker wanting to sharpen your articulation, Alice's opera-trained ear will guide you to clearer, more confident communication.</p>
            </div>
        </div>
    </div>
</section>

<!-- Row 1: What's Included | How It Works (cream) -->
<section class="py-24 bg-[#F8F3EA] text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20">
            <div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8">What's Included</h2>
                <ul class="space-y-4">
                    {[
                        'Accent refinement & clarity  - speak clearly without losing your identity',
                        'Articulation & intonation patterns  - the music of professional English',
                        'Vowel and consonant precision  - targeted work on specific sounds',
                        'Professional vocabulary & phrasing  - sound confident in any context',
                        'Rhythm, stress & connected speech  - natural-sounding fluency',
                        'Personalised exercises & practice plans to use between sessions',
                    ].map(item => (
                        <li class="flex items-start gap-3 text-gray-600 font-light">
                            <iconify-icon icon="mdi:check" width="20" class="text-[var(--pkg-accent)] mt-0.5 flex-shrink-0"></iconify-icon>
                            {item}
                        </li>
                    ))}
                </ul>
            </div>
            <div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8">How It Works</h2>
                <div class="space-y-6">
                    {[
                        { step: '01', title: 'Discovery Call', desc: 'A free 15-minute conversation to understand your pronunciation goals.' },
                        { step: '02', title: 'Assessment', desc: 'Alice listens to your speech patterns and identifies areas for improvement.' },
                        { step: '03', title: 'Targeted Sessions', desc: 'Focused coaching on the specific sounds, patterns, and habits that matter most.' },
                        { step: '04', title: 'Practice & Progress', desc: 'Custom exercises to reinforce learning between sessions.' },
                    ].map(s => (
                        <div class="flex gap-4">
                            <span class="text-[var(--pkg-accent)] font-serif text-2xl font-medium w-10 flex-shrink-0">{s.step}</span>
                            <div>
                                <h4 class="font-medium text-[#050615] mb-1">{s.title}</h4>
                                <p class="text-sm text-gray-500 font-light">{s.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Row 2: What You'll Take Away (white) -->
<section class="py-24 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="text-center mb-14">
            <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-6">What You'll Take Away</h2>
            <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {[
                { icon: 'solar:volume-loud-bold', title: 'Clearly Understood', desc: 'Articulation that lands every word the first time.' },
                { icon: 'solar:music-note-2-bold', title: 'Naturally Fluent', desc: 'Rhythm and intonation that sound effortless, not rehearsed.' },
                { icon: 'solar:microphone-bold', title: 'Speak Up Without Hesitation', desc: 'No more holding back in meetings, calls, or presentations.' },
            ].map(o => (
                <div class="flex items-start gap-4">
                    <iconify-icon icon={o.icon} width="24" class="text-[var(--pkg-accent)] mt-1 flex-shrink-0"></iconify-icon>
                    <div>
                        <h3 class="font-serif text-xl text-[#050615] mb-2">{o.title}</h3>
                        <p class="text-gray-600 font-light leading-relaxed">{o.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- Row 3: Alice's Edge + Alice photo (cream) -->
<section class="py-24 bg-[#F8F3EA] text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
            <div>
                <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">Alice's Edge</span>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-6 leading-tight">An opera-trained ear hears what others miss.</h2>
                <p class="text-gray-600 font-light leading-relaxed mb-4">As an opera-trained singer, Alice has a finely tuned ear for voice, accent, articulation and intonation that goes far beyond typical pronunciation coaching. She can hear precisely where a word bends, where a vowel narrows, where a rhythm trips  -  and show you exactly how to fix it.</p>
                <p class="text-gray-600 font-light leading-relaxed">Available online via Zoom (worldwide) or in-person in London. Sessions are typically 60 minutes.</p>
            </div>
            <img src="/images/about-alice-deville.jpg" alt="Alice Deville - voice and pronunciation coach" class="w-full rounded-sm">
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="py-20 bg-[#050615]">
    <div class="max-w-[960px] mx-auto px-6">
        <div class="text-center mb-12">
            <span class="text-[10px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">FAQs</span>
            <h2 class="text-3xl md:text-4xl font-serif text-white mb-6">Frequently Asked Questions</h2>
            <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto"></div>
        </div>
        <div class="space-y-4" itemscope itemtype="https://schema.org/FAQPage">
            {faqs.map((faq: any) => (
                <details class="group border border-white/10 rounded-sm" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <summary class="flex items-center justify-between p-6 cursor-pointer">
                        <span class="font-medium text-white pr-4" itemprop="name">{faq.q}</span>
                        <iconify-icon icon="solar:alt-arrow-down-bold" width="16" class="text-[var(--pkg-accent)] flex-shrink-0 transition-transform duration-200 group-open:rotate-180"></iconify-icon>
                    </summary>
                    <div class="px-6 pb-6 pt-0" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p class="text-sm text-gray-400 font-light leading-relaxed" data-faq-answer itemprop="text">{faq.a}</p>
                        {faq.link && <a href={faq.link} class="inline-block mt-3 text-[10px] uppercase tracking-[0.15em] font-medium text-[var(--pkg-accent)] hover:text-white transition-colors">{faq.cta} &rarr;</a>}
                    </div>
                </details>
            ))}
        </div>
    </div>
</section>

<GoogleReview text="Alice's expertise in English RP pronunciation has been invaluable. She demonstrated a keen ability to identify my weaknesses and tailor her lessons to meet my specific needs. My confidence in speaking English has soared, and I feel much more at ease in both professional and social settings." author="Maria Luisa F" date="1 year ago" />

<!-- CTA -->
<section class="py-20 bg-white">
    <div class="max-w-[800px] mx-auto px-6 text-center">
        <h2 class="text-3xl font-serif text-[#050615] mb-4">Ready to Speak With Clarity?</h2>
        <p class="text-gray-500 font-light mb-8 max-w-lg mx-auto">Book a free discovery call and let's explore how to refine your pronunciation.</p>
        <a href="/free-consultation" class="btn-primary">Book a Free Discovery Call</a>
    </div>
</section>

</div>
</Base>
