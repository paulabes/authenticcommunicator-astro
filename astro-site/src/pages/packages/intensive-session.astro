---
import Base from '../../layouts/Base.astro';
import GoogleReview from '../../components/GoogleReview.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { serviceSchema, breadcrumbSchema, faqPageSchema, siteOrigin } from '../../data/site';

const description = 'The Intensive 90-Minute Session is a single, deep coaching session with Alice Deville, designed around one specific upcoming event. Pitch, keynote, interview, or TED talk - leave with a plan, not a guess.';

const faqs = [
  {
    q: 'What can I cover in 90 minutes?',
    a: "A focused 90-minute Intensive Session covers enough ground to transform a single upcoming moment - a pitch, keynote, interview, podcast appearance, or difficult conversation. Most clients send me the content or context in advance so we use the first 10 minutes to land the goal, spend 60 minutes rehearsing and reshaping delivery with real-time feedback, and close with a written summary of the 3 to 5 practical techniques to take into the room. By the end you leave with a clearer structure for what you are going to say, vocal and physical tools you can use under pressure, and evidence from the session itself that you can already do it.",
    link: '/free-consultation',
    cta: 'Book Your Session',
  },
  {
    q: 'Do I need to prepare anything?',
    a: "Ideally, yes. If you have specific content - a pitch deck, presentation script, interview questions, a piece of video from a previous talk, or the text of the speech - send it to me at least 24 hours before the session so we can hit the ground running. If there is no specific content yet, that is also fine; we will spend a short block up front identifying the exact use case and then work on general delivery, nerves management, or vocal technique using live improvisation and feedback. The more concrete the context you bring, the more tailored the 90 minutes becomes.",
  },
  {
    q: 'Is one session really enough?',
    a: "For many clients, yes. A focused 90-minute Intensive Session can be genuinely transformative when you have one clear event to prepare for, because all 90 minutes pull in the same direction and the feedback compounds quickly. Around 30 to 40 percent of Intensive clients book a second session in the week before the event as a dress rehearsal, and that is the most common follow-up. If you want something deeper and more structural - lasting change in how you show up at work, not just for one event - the Confident Speaker Package is the right next step, but there is no obligation to continue after the first session.",
    link: '/contact',
    cta: 'Get in Touch',
  },
  {
    q: 'How does the online session work?',
    a: "We meet on Zoom at the time you book, and I will send a calendar invite with the link as soon as payment clears. You will need a quiet room where you will not be interrupted, a reasonably stable internet connection, and a device with a working camera and microphone at roughly eye height so I can see both your posture and your face. Headphones are helpful but not essential. If you are presenting with slides, share your screen as you would in the real event so we can rehearse the full experience. A short pre-session email walks you through camera and lighting tips so the space works for your voice.",
  },
];
---

<Base
    title="Intensive 90-Minute Session"
    description={description}
    image="/images/intensive-90-minute-session.jpg"
    jsonLd={[
      serviceSchema({
        name: 'Intensive 90-Minute Session',
        slug: 'intensive-session',
        serviceType: '90-minute 1:1 coaching for a specific high-stakes event',
        description,
        image: '/images/intensive-90-minute-session.jpg',
      }),
      breadcrumbSchema([
        { name: 'Home', url: '/' },
        { name: 'Packages', url: '/packages' },
        { name: 'Intensive 90-Minute Session', url: '/packages/intensive-session' },
      ]),
      faqPageSchema(faqs, `${siteOrigin}/packages/intensive-session`),
    ]}
>

<style>
  .pkg { --pkg-accent: #7A4E5E; }
</style>

<div class="pkg">

<!-- Hero Background -->
<div class="fixed top-0 w-full h-screen -z-10">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/authentic-communicator-global-alice.jpg'); opacity: 0.8;"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#050615] via-[#050615]/90 to-[#050615]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050615]/50 to-[#050615]"></div>
</div>

<!-- Hero -->
<section class="pt-36 pb-16 lg:px-12 px-6">
    <div class="max-w-[1200px] mx-auto text-center">
        <div class="flex justify-center mb-5">
            <Breadcrumbs items={[
                { name: 'Home', url: '/' },
                { name: 'Packages', url: '/packages' },
                { name: 'Intensive 90-Minute Session' },
            ]} />
        </div>
        <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">Coaching Package</span>
        <h1 class="text-5xl md:text-6xl font-serif text-white mb-6">Intensive 90-Minute Session</h1>
        <p class="text-gray-400 font-light max-w-xl text-lg leading-relaxed mx-auto">Transform your confidence in a single online session. Focused, practical, and immediately applicable.</p>
    </div>
</section>

<!-- Intro: image + paragraph, airy -->
<section class="py-28 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <img src="/images/intensive-90-minute-session.jpg" alt="Intensive 90-Minute Coaching Session" class="w-full rounded-sm">
            <div class="lg:pr-6">
                <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-5">Who Is This For</span>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8 leading-tight">One session. One big moment. Ready.</h2>
                <p class="text-gray-600 font-light leading-relaxed text-lg">This is for professionals who need focused, immediate results. You have a presentation next week, a media appearance coming up, a job interview that matters, or a pitch that could change everything. You don't need a long programme  -  you need a single powerful session that gives you the tools and confidence to deliver.</p>
            </div>
        </div>
    </div>
</section>

<!-- Row 1: What's Included | How It Works (cream) -->
<section class="py-24 bg-[#F8F3EA] text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20">
            <div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8">What's Included</h2>
                <ul class="space-y-4">
                    {[
                        'Targeted coaching tailored to your specific upcoming event',
                        'Practical vocal and delivery techniques you can use immediately',
                        'Real-time practice and feedback on your actual content',
                        'Strategies for managing nerves in the moment',
                        'Follow-up notes and exercises emailed after the session',
                        'Available online via Zoom  - anywhere in the world',
                    ].map(item => (
                        <li class="flex items-start gap-3 text-gray-600 font-light">
                            <iconify-icon icon="mdi:check" width="20" class="text-[var(--pkg-accent)] mt-0.5 flex-shrink-0"></iconify-icon>
                            {item}
                        </li>
                    ))}
                </ul>
            </div>
            <div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8">How It Works</h2>
                <div class="space-y-6">
                    {[
                        { step: '01', title: 'Book', desc: 'Get in touch and tell me what you\'re preparing for.' },
                        { step: '02', title: 'Prepare', desc: 'Share your content or context in advance so we hit the ground running.' },
                        { step: '03', title: 'Transform', desc: '90 minutes of focused coaching, practice, and real-time feedback.' },
                        { step: '04', title: 'Deliver', desc: 'Walk away with techniques, confidence, and follow-up notes to keep practising.' },
                    ].map(s => (
                        <div class="flex gap-4">
                            <span class="text-[var(--pkg-accent)] font-serif text-2xl font-medium w-10 flex-shrink-0">{s.step}</span>
                            <div>
                                <h4 class="font-medium text-[#050615] mb-1">{s.title}</h4>
                                <p class="text-sm text-gray-500 font-light">{s.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Row 2: What You'll Take Away (white) -->
<section class="py-24 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="text-center mb-14">
            <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-6">What You'll Take Away</h2>
            <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {[
                { icon: 'solar:clock-circle-bold', title: 'Walk In Ready', desc: 'Leave with the exact tools you need for the specific moment ahead.' },
                { icon: 'solar:heart-pulse-bold', title: 'Nerves Managed', desc: 'Practical in-the-moment techniques for when your heart starts pounding.' },
                { icon: 'solar:notebook-bold', title: 'A Follow-Up Kit', desc: 'Written notes and exercises emailed so the work lives on past the session.' },
            ].map(o => (
                <div class="flex items-start gap-4">
                    <iconify-icon icon={o.icon} width="24" class="text-[var(--pkg-accent)] mt-1 flex-shrink-0"></iconify-icon>
                    <div>
                        <h3 class="font-serif text-xl text-[#050615] mb-2">{o.title}</h3>
                        <p class="text-gray-600 font-light leading-relaxed">{o.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- Row 3: Perfect For + Alice photo (cream) -->
<section class="py-24 bg-[#F8F3EA] text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
            <div>
                <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">Perfect For</span>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8 leading-tight">The moments where preparation pays for itself.</h2>
                <div class="grid grid-cols-2 gap-x-6 gap-y-3">
                    {['Keynote prep', 'Board presentations', 'Media appearances', 'Job interviews', 'Wedding speeches', 'Pitch rehearsals', 'Panel discussions', 'Conference talks'].map(item => (
                        <div class="flex items-center gap-2 text-sm text-gray-600 font-light">
                            <iconify-icon icon="mdi:check" width="16" class="text-[var(--pkg-accent)] flex-shrink-0"></iconify-icon>
                            {item}
                        </div>
                    ))}
                </div>
            </div>
            <img src="/images/authentic-communicator-global-alice-mobile.jpg" alt="Alice Deville - intensive coaching" class="w-full">
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="py-20 bg-[#050615]">
    <div class="max-w-[960px] mx-auto px-6">
        <div class="text-center mb-12">
            <span class="text-[10px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">FAQs</span>
            <h2 class="text-3xl md:text-4xl font-serif text-white mb-6">Frequently Asked Questions</h2>
            <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto"></div>
        </div>
        <div class="space-y-4" itemscope itemtype="https://schema.org/FAQPage">
            {faqs.map((faq: any) => (
                <details class="group border border-white/10 rounded-sm" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <summary class="flex items-center justify-between p-6 cursor-pointer">
                        <span class="font-medium text-white pr-4" itemprop="name">{faq.q}</span>
                        <iconify-icon icon="solar:alt-arrow-down-bold" width="16" class="text-[var(--pkg-accent)] flex-shrink-0 transition-transform duration-200 group-open:rotate-180"></iconify-icon>
                    </summary>
                    <div class="px-6 pb-6 pt-0" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p class="text-sm text-gray-400 font-light leading-relaxed" data-faq-answer itemprop="text">{faq.a}</p>
                        {faq.link && <a href={faq.link} class="inline-block mt-3 text-[10px] uppercase tracking-[0.15em] font-medium text-[var(--pkg-accent)] hover:text-white transition-colors">{faq.cta} &rarr;</a>}
                    </div>
                </details>
            ))}
        </div>
    </div>
</section>

<GoogleReview text="Alice was a pleasure to work with. A very specific focus was required and Alice helped a lot and opened up my mind giving me many tools to work with. Tools that should help me develop over the coming months! Very grateful." author="Neil Mandel" date="Recently" />

<!-- CTA -->
<section class="py-20 bg-white">
    <div class="max-w-[800px] mx-auto px-6 text-center">
        <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto mb-8"></div>
        <h2 class="text-3xl font-serif text-[#050615] mb-4">Ready for Your 90 Minutes?</h2>
        <p class="text-gray-500 font-light mb-8 max-w-lg mx-auto">Book your intensive session and walk into your next speaking moment with confidence.</p>
        <a href="/contact" class="btn-primary">Book Your Session</a>
    </div>
</section>

</div>
</Base>
