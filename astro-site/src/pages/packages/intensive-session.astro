---
import Base from '../../layouts/Base.astro';
import GoogleReview from '../../components/GoogleReview.astro';
---

<Base title="Intensive 90-Minute Session">

<style>
  .pkg { --pkg-accent: #7A4E5E; }
</style>

<div class="pkg">

<!-- Hero Background -->
<div class="fixed top-0 w-full h-screen -z-10">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/authentic-communicator-global-alice.jpg'); opacity: 0.8;"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#050615] via-[#050615]/90 to-[#050615]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050615]/50 to-[#050615]"></div>
</div>

<!-- Hero -->
<section class="pt-36 pb-16 lg:px-12 px-6">
    <div class="max-w-[1200px] mx-auto text-center">
        <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">Coaching Package</span>
        <h1 class="text-5xl md:text-6xl font-serif text-white mb-6">Intensive 90-Minute Session</h1>
        <p class="text-gray-400 font-light max-w-xl text-lg leading-relaxed mx-auto">Transform your confidence in a single online session. Focused, practical, and immediately applicable.</p>
        <div class="mt-10 text-center">
            <p class="text-[10px] uppercase tracking-widest text-gray-600 mb-4">Trusted by professionals at</p>
            <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12"><img src="/logos/blackrock.svg" alt="BlackRock" class="h-5 invert opacity-40"><img src="/logos/deloitte.svg" alt="Deloitte" class="h-5 invert opacity-40"><img src="/logos/jpmorgan.svg" alt="JP Morgan" class="h-5 invert opacity-40"><img src="/logos/google.svg" alt="Google" class="h-6 invert opacity-40"><img src="/logos/downing-street.svg" alt="10 Downing Street" class="h-4 invert opacity-40"></div>
        </div>
    </div>
</section>

<!-- Intro: image + paragraph, airy -->
<section class="py-28 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <img src="/images/intensive-90-minute-session.jpg" alt="Intensive 90-Minute Coaching Session" class="w-full rounded-sm">
            <div class="lg:pr-6">
                <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-5">Who Is This For</span>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8 leading-tight">One session. One big moment. Ready.</h2>
                <p class="text-gray-600 font-light leading-relaxed text-lg">This is for professionals who need focused, immediate results. You have a presentation next week, a media appearance coming up, a job interview that matters, or a pitch that could change everything. You don't need a long programme  -  you need a single powerful session that gives you the tools and confidence to deliver.</p>
            </div>
        </div>
    </div>
</section>

<!-- Details: bullets + perfect for + how it works -->
<section class="py-24 bg-[#FAFAF8] text-[#050615]">
    <div class="max-w-[820px] mx-auto px-6">
        <h3 class="text-2xl font-serif text-[#050615] mb-8">What's Included</h3>
        <ul class="space-y-4 mb-16">
            {[
                'Targeted coaching tailored to your specific upcoming event',
                'Practical vocal and delivery techniques you can use immediately',
                'Real-time practice and feedback on your actual content',
                'Strategies for managing nerves in the moment',
                'Follow-up notes and exercises emailed after the session',
                'Available online via Zoom  - anywhere in the world',
            ].map(item => (
                <li class="flex items-start gap-3 text-gray-600 font-light">
                    <iconify-icon icon="solar:check-circle-linear" width="20" class="text-[var(--pkg-accent)] mt-0.5 flex-shrink-0"></iconify-icon>
                    {item}
                </li>
            ))}
        </ul>

        <h3 class="text-2xl font-serif text-[#050615] mb-8">Perfect For</h3>
        <div class="grid grid-cols-2 gap-4 mb-16">
            {['Keynote prep', 'Board presentations', 'Media appearances', 'Job interviews', 'Wedding speeches', 'Pitch rehearsals', 'Panel discussions', 'Conference talks'].map(item => (
                <div class="flex items-center gap-2 text-sm text-gray-600 font-light">
                    <iconify-icon icon="solar:arrow-right-linear" width="14" class="text-[var(--pkg-accent)]"></iconify-icon>
                    {item}
                </div>
            ))}
        </div>

        <h3 class="text-2xl font-serif text-[#050615] mb-8">How It Works</h3>
        <div class="space-y-6">
            {[
                { step: '01', title: 'Book', desc: 'Get in touch and tell me what you\'re preparing for.' },
                { step: '02', title: 'Prepare', desc: 'Share your content or context in advance so we hit the ground running.' },
                { step: '03', title: 'Transform', desc: '90 minutes of focused coaching, practice, and real-time feedback.' },
                { step: '04', title: 'Deliver', desc: 'Walk away with techniques, confidence, and follow-up notes to keep practising.' },
            ].map(s => (
                <div class="flex gap-4">
                    <span class="text-[var(--pkg-accent)] font-serif text-2xl font-medium w-10 flex-shrink-0">{s.step}</span>
                    <div>
                        <h4 class="font-medium text-[#050615] mb-1">{s.title}</h4>
                        <p class="text-sm text-gray-500 font-light">{s.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="py-20 bg-[#050615]">
    <div class="max-w-[800px] mx-auto px-6">
        <div class="text-center mb-12">
            <span class="text-[10px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">FAQs</span>
            <h2 class="text-3xl md:text-4xl font-serif text-white mb-6">Frequently Asked Questions</h2>
            <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto"></div>
        </div>
        <div class="space-y-4">
            {[
                { q: 'What can I cover in 90 minutes?', a: "A lot. We'll focus on your specific needs - whether that's a presentation you're rehearsing, managing nerves, vocal technique, or general confidence. You'll walk away with practical tools you can use immediately.", link: '/free-consultation', cta: 'Book Your Session' },
                { q: 'Do I need to prepare anything?', a: "If you have specific content to work on (a speech, presentation, or pitch), share it in advance so we can hit the ground running. If not, we'll work on your general communication skills." },
                { q: 'Is one session really enough?', a: "For many clients, yes. A focused 90-minute session can be genuinely transformative. If you want ongoing support after, we can discuss a package - but there's no pressure.", link: '/contact', cta: 'Get in Touch' },
                { q: 'How does the online session work?', a: "We meet on Zoom. I'll send you a link after booking. All you need is a quiet space, a stable internet connection, and a device with a camera and microphone." },
            ].map(faq => (
                <details class="group border border-white/10 rounded-sm">
                    <summary class="flex items-center justify-between p-6 cursor-pointer">
                        <span class="font-medium text-white pr-4">{faq.q}</span>
                        <iconify-icon icon="solar:alt-arrow-down-linear" width="16" class="text-[var(--pkg-accent)] flex-shrink-0 transition-transform duration-200 group-open:rotate-180"></iconify-icon>
                    </summary>
                    <div class="px-6 pb-6 pt-0">
                        <p class="text-sm text-gray-400 font-light leading-relaxed">{faq.a}</p>
                        {faq.link && <a href={faq.link} class="inline-block mt-3 text-[10px] uppercase tracking-[0.15em] font-medium text-[var(--pkg-accent)] hover:text-white transition-colors">{faq.cta} &rarr;</a>}
                    </div>
                </details>
            ))}
        </div>
    </div>
</section>

<GoogleReview size="small" />

<!-- CTA -->
<section class="py-20 bg-white">
    <div class="max-w-[800px] mx-auto px-6 text-center">
        <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto mb-8"></div>
        <h2 class="text-3xl font-serif text-[#050615] mb-4">Ready for Your 90 Minutes?</h2>
        <p class="text-gray-500 font-light mb-8 max-w-lg mx-auto">Book your intensive session and walk into your next speaking moment with confidence.</p>
        <a href="/contact" class="btn-primary">Book Your Session</a>
    </div>
</section>

</div>
</Base>
