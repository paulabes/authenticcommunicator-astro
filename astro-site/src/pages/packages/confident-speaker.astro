---
import Base from '../../layouts/Base.astro';
import GoogleReview from '../../components/GoogleReview.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { serviceSchema, breadcrumbSchema, faqPageSchema, siteOrigin } from '../../data/site';

const description = 'The Confident Speaker Package is a bespoke 1:1 public speaking coaching programme with Alice Deville. Build body-level speaking confidence, remove avoidance patterns, and own the room at your next keynote or pitch.';

const faqs = [
  {
    q: 'How many sessions are in the package?',
    a: "The Confident Speaker Package is typically 4 to 8 sessions across 6 to 12 weeks, tailored to your goals and starting point. Four sessions is enough for clients preparing for a single significant event - a keynote, conference talk, or board presentation - who already have a base of confidence and want to sharpen delivery. Eight sessions is more common for professionals who want to build a lasting, body-level change in how they speak in every meeting, not just the big ones. Sessions are 60 to 90 minutes and spaced weekly or fortnightly so you have time to practise between them. We will agree the exact shape on the free consultation.",
    link: '/free-consultation',
    cta: 'Discuss in a Free Consultation',
  },
  {
    q: 'Can you help with a specific upcoming event?',
    a: "Yes. Around half of my Confident Speaker clients arrive with a named event: a TEDx talk, a pitch to investors, a keynote, a conference panel, a board presentation, or a best-man speech. We work backwards from the event date, rehearse against the real content and room, and build in time for technical run-throughs. I will help you with the material itself where useful - structure, opening and closing lines, the cuts that will tighten pacing - as well as the vocal and physical craft of delivering it. If the event is in less than two weeks, the Intensive 90-Minute Session is often a better fit.",
    link: '/contact',
    cta: 'Get in Touch',
  },
  {
    q: "I get very nervous before speaking. Can coaching really help?",
    a: "Yes, and this is one of the most common reasons clients come to me. As a former opera performer I spent years managing my own performance anxiety on stages where there is no second take, and the techniques that work are physical and teachable, not affirmations. We work on breath patterns, grounding, and recovery tactics that calm the nervous system in the minutes before you speak and during the moment itself. Clients typically notice a real difference within the first two or three sessions. Coaching will not make the stakes smaller, but it will give you a reliable way to stay present and clear when the pressure is on.",
  },
  {
    q: 'Are sessions online or in-person?',
    a: "Both. Sessions are available worldwide via Zoom or in-person in London, and you can mix the two over the course of the package. Online sessions work well for almost every aspect of voice, delivery, and presentation coaching - I will guide you through camera, mic, and lighting setup so the space you work from serves your voice. In-person is useful when we need a larger room to rehearse stage movement, simulate an audience, or work through stamina on a long talk. Most international clients at BlackRock, Deloitte, JP Morgan and Google work entirely on Zoom and see the same results as in-person clients.",
  },
];
---

<Base
    title="Confident Speaker Package"
    description={description}
    image="/images/confident-speaker-package.jpg"
    jsonLd={[
      serviceSchema({
        name: 'Confident Speaker Package',
        slug: 'confident-speaker',
        serviceType: 'Public speaking coaching',
        description,
        image: '/images/confident-speaker-package.jpg',
      }),
      breadcrumbSchema([
        { name: 'Home', url: '/' },
        { name: 'Packages', url: '/packages' },
        { name: 'Confident Speaker', url: '/packages/confident-speaker' },
      ]),
      faqPageSchema(faqs, `${siteOrigin}/packages/confident-speaker`),
    ]}
>

<style>
  .pkg { --pkg-accent: #B5654A; }
</style>

<div class="pkg">

<!-- Hero Background -->
<div class="fixed top-0 w-full h-screen -z-10">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/authentic-communicator-global-alice.jpg'); opacity: 0.8;"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#050615] via-[#050615]/90 to-[#050615]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050615]/50 to-[#050615]"></div>
</div>

<!-- Hero -->
<section class="pt-36 pb-16 lg:px-12 px-6">
    <div class="max-w-[1200px] mx-auto text-center">
        <div class="flex justify-center mb-5">
            <Breadcrumbs items={[
                { name: 'Home', url: '/' },
                { name: 'Packages', url: '/packages' },
                { name: 'Confident Speaker' },
            ]} />
        </div>
        <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">Coaching Package</span>
        <h1 class="text-5xl md:text-6xl font-serif text-white mb-6">Confident Speaker Package</h1>
        <p class="text-gray-400 font-light max-w-xl text-lg leading-relaxed mx-auto">Mastering the art of public speaking. A structured programme to build your confidence, refine your delivery, and help you connect with any audience.</p>
    </div>
</section>

<!-- Intro: image + paragraph, airy -->
<section class="py-28 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <img src="/images/confident-speaker-package.jpg" alt="Confident Speaker - Coaching Session" class="w-full rounded-sm">
            <div class="lg:pr-6">
                <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-5">Who Is This For</span>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8 leading-tight">Speak with confidence, wherever the stage.</h2>
                <p class="text-gray-600 font-light leading-relaxed text-lg">This package is for professionals who want to speak with confidence and impact  -  whether that's presenting to a boardroom, delivering a keynote, leading a team meeting, or pitching to investors. If speaking in front of others makes you nervous, or if you know your message is strong but your delivery lets you down, this is for you.</p>
            </div>
        </div>
    </div>
</section>

<!-- Row 1: What's Included | How It Works (cream) -->
<section class="py-24 bg-[#F8F3EA] text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20">
            <div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8">What's Included</h2>
                <ul class="space-y-4">
                    {[
                        'Vocal technique & projection  - learn to fill a room without straining',
                        'Managing nerves & performance anxiety  - practical tools that work under pressure',
                        'Engaging storytelling & structure  - craft talks that hold attention from start to finish',
                        'Body language & stage presence  - own the space with natural authority',
                        'Pace, pausing & emphasis  - the rhythm that makes speakers magnetic',
                        'Personalised feedback on your real presentations and pitches',
                    ].map(item => (
                        <li class="flex items-start gap-3 text-gray-600 font-light">
                            <iconify-icon icon="mdi:check" width="20" class="text-[var(--pkg-accent)] mt-0.5 flex-shrink-0"></iconify-icon>
                            {item}
                        </li>
                    ))}
                </ul>
            </div>
            <div>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-8">How It Works</h2>
                <div class="space-y-6">
                    {[
                        { step: '01', title: 'Discovery Call', desc: 'A free 15-minute conversation to understand your goals and challenges.' },
                        { step: '02', title: 'Tailored Programme', desc: 'A coaching plan designed around your specific speaking contexts and objectives.' },
                        { step: '03', title: 'Coaching Sessions', desc: 'Focused sessions combining technique work, practice, and real-time feedback.' },
                        { step: '04', title: 'Ongoing Support', desc: 'Follow-up notes, exercises, and support between sessions.' },
                    ].map(s => (
                        <div class="flex gap-4">
                            <span class="text-[var(--pkg-accent)] font-serif text-2xl font-medium w-10 flex-shrink-0">{s.step}</span>
                            <div>
                                <h4 class="font-medium text-[#050615] mb-1">{s.title}</h4>
                                <p class="text-sm text-gray-500 font-light">{s.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Row 2: What You'll Take Away (white) -->
<section class="py-24 bg-white text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="text-center mb-14">
            <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-6">What You'll Take Away</h2>
            <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {[
                { icon: 'solar:crown-bold', title: 'Command the Room', desc: 'Stand, breathe, and own the space before you\'ve said a word.' },
                { icon: 'solar:shield-check-bold', title: 'Steady Under Pressure', desc: 'Tools that hold up when the stakes and stress are high.' },
                { icon: 'solar:star-fall-bold', title: 'Memorable Delivery', desc: 'Stories, structure and pacing audiences remember long after.' },
            ].map(o => (
                <div class="flex items-start gap-4">
                    <iconify-icon icon={o.icon} width="24" class="text-[var(--pkg-accent)] mt-1 flex-shrink-0"></iconify-icon>
                    <div>
                        <h3 class="font-serif text-xl text-[#050615] mb-2">{o.title}</h3>
                        <p class="text-gray-600 font-light leading-relaxed">{o.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- Row 3: Format + Alice photo (cream) -->
<section class="py-24 bg-[#F8F3EA] text-[#050615]">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
            <div>
                <span class="text-[11px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">Format</span>
                <h2 class="text-3xl md:text-4xl font-serif text-[#050615] mb-6 leading-tight">Online, in-person, or both - tailored around you.</h2>
                <p class="text-gray-600 font-light leading-relaxed mb-4">Available online via Zoom (worldwide) or in-person in London. Sessions are typically 60 minutes.</p>
                <p class="text-gray-600 font-light leading-relaxed">Package length is tailored to your goals and calendar. Most clients work with me over four to eight sessions, but I'll design the right shape for you on our first call.</p>
            </div>
            <img src="/images/Alice-Deville-London.jpg" alt="Alice Deville coaching in London" class="w-full rounded-sm">
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="py-20 bg-[#050615]">
    <div class="max-w-[960px] mx-auto px-6">
        <div class="text-center mb-12">
            <span class="text-[10px] tracking-[0.25em] text-[var(--pkg-accent)] uppercase font-medium block mb-4">FAQs</span>
            <h2 class="text-3xl md:text-4xl font-serif text-white mb-6">Frequently Asked Questions</h2>
            <div class="w-16 h-[1px] bg-[var(--pkg-accent)] mx-auto"></div>
        </div>
        <div class="space-y-4" itemscope itemtype="https://schema.org/FAQPage">
            {faqs.map((faq: any) => (
                <details class="group border border-white/10 rounded-sm" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <summary class="flex items-center justify-between p-6 cursor-pointer">
                        <span class="font-medium text-white pr-4" itemprop="name">{faq.q}</span>
                        <iconify-icon icon="solar:alt-arrow-down-bold" width="16" class="text-[var(--pkg-accent)] flex-shrink-0 transition-transform duration-200 group-open:rotate-180"></iconify-icon>
                    </summary>
                    <div class="px-6 pb-6 pt-0" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p class="text-sm text-gray-400 font-light leading-relaxed" data-faq-answer itemprop="text">{faq.a}</p>
                        {faq.link && <a href={faq.link} class="inline-block mt-3 text-[10px] uppercase tracking-[0.15em] font-medium text-[var(--pkg-accent)] hover:text-white transition-colors">{faq.cta} &rarr;</a>}
                    </div>
                </details>
            ))}
        </div>
    </div>
</section>

<GoogleReview text="Working with Alice was a game-changer. She helped me sharpen my public speaking for both in-person and the virtual. Her methods are practical and easy to replicate in any setting. If you want to level up your delivery, Alice is the one to see!" author="Shane Buckley" date="1 month ago" />

<!-- CTA -->
<section class="py-20 bg-white">
    <div class="max-w-[800px] mx-auto px-6 text-center">
        <h2 class="text-3xl font-serif text-[#050615] mb-4">Ready to Become a Confident Speaker?</h2>
        <p class="text-gray-500 font-light mb-8 max-w-lg mx-auto">Book a free discovery call and let's discuss how this package can help you speak with impact.</p>
        <a href="/free-consultation" class="btn-primary">Book a Free Discovery Call</a>
    </div>
</section>

</div>
</Base>
